{
  "name": "@portfolio/backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts --mode=upsert --scale=medium --seed=phase2-default-001",
    "db:seed:reset": "tsx src/db/seed.ts --mode=reset --scale=medium --seed=phase2-default-001",
    "db:seed:smoke": "tsx src/db/seed.ts --mode=upsert --scale=smoke --seed=phase2-default-001",
    "pricing-fx:smoke": "tsx src/modules/pricing-fx/services/pricing-fx-ingestion-smoke.ts",
    "api:smoke:auth": "tsx src/smoke/authenticated-api-smoke.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@portfolio/contracts": "workspace:*",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/pg": "^8.15.4",
    "@types/node": "^22.8.7",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
