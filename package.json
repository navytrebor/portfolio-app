{
  "name": "portfolio-app",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:frontend": "pnpm --filter @portfolio/frontend dev",
    "dev:backend": "pnpm --filter @portfolio/backend dev",
    "build": "pnpm -r build",
    "check": "pnpm -r typecheck"
  }
}
